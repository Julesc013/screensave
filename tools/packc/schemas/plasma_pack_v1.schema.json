{
  "schema": "screensave.pack.v1",
  "kind": "screensave.plasma.v2",
  "status": "v1-candidate",
  "required_top_level": [
    "schema_version",
    "pack_id",
    "kind",
    "product",
    "name",
    "author",
    "license",
    "provenance",
    "proof_profile",
    "compatibility",
    "plasma_spec_v2"
  ],
  "forbidden": [
    "scripts",
    "dlls",
    "macros",
    "commands",
    "network_references",
    "absolute_paths",
    "parent_traversal"
  ],
  "bounds": {
    "max_string_length": 96,
    "max_expanded_bytes": 65536,
    "max_output_files": 4
  },
  "admitted_proof_profiles": [
    "plasma.v2.reference.preview",
    "plasma.v2.visualintent.preview"
  ],
  "claim_boundary": "VisualIntent profile references compile as data-only Plasma v2 spec candidates; they do not execute, mutate runtime, certify compatibility, or promote release."
}
