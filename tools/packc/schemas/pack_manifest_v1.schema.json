{
  "additionalProperties": false,
  "properties": {
    "claim_boundary": {
      "type": "string"
    },
    "content_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "data_only": {
      "const": true,
      "type": "boolean"
    },
    "file_count": {
      "maximum": 4,
      "minimum": 1,
      "type": "integer"
    },
    "kind": {
      "const": "screensave.plasma.v2",
      "type": "string"
    },
    "pack_id": {
      "pattern": "^[A-Za-z0-9_.-]+$",
      "type": "string"
    },
    "pack_manifest_schema": {
      "const": "screensave.pack_manifest.v1",
      "type": "string"
    },
    "pack_schema": {
      "const": "screensave.pack.v1",
      "type": "string"
    },
    "pack_status": {
      "const": "v1-candidate",
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "provenance": {
      "type": "string"
    },
    "compatibility_range": {
      "additionalProperties": false,
      "properties": {
        "maximum_schema_version": {
          "const": 2,
          "type": "integer"
        },
        "minimum_schema_version": {
          "const": 2,
          "type": "integer"
        }
      },
      "required": [
        "minimum_schema_version",
        "maximum_schema_version"
      ],
      "type": "object"
    },
    "product": {
      "const": "plasma",
      "type": "string"
    },
    "proof_profile": {
      "enum": [
        "plasma.v2.reference.preview",
        "plasma.v2.visualintent.preview"
      ],
      "type": "string"
    },
    "source_ref": {
      "type": "string"
    }
  },
  "required": [
    "pack_manifest_schema",
    "pack_schema",
    "pack_status",
    "pack_id",
    "kind",
    "product",
    "author",
    "license",
    "provenance",
    "compatibility_range",
    "proof_profile",
    "file_count",
    "data_only",
    "content_sha256",
    "source_ref",
    "claim_boundary"
  ],
  "schema": "screensave.pack_manifest.v1",
  "type": "object"
}
