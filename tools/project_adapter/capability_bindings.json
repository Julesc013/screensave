{
  "schema_version": 1,
  "binding_id": "screensave-project-adapter-capabilities-v0",
  "status": "active",
  "owner": "ScreenSave",
  "output_root": "out/aide/screensave-project-adapter/invocations",
  "mutation_policy": "no source mutation, no branch mutation, no release publication, no compatibility certification, no artistic acceptance",
  "capabilities": [
    {
      "name": "screensave.project.status",
      "command": "status",
      "effect": "read-only project state receipt",
      "deterministic": true,
      "argv": ["python", "tools/project_adapter/screensave_project.py", "status"],
      "decoder_schema": "tools/project_adapter/receipt_schemas.json#/commands/status",
      "output_policy": "stdout JSON only",
      "input_policy": "none",
      "timeout_seconds": 10,
      "state_probe": "git revision and PROJECT_STATE.toml"
    },
    {
      "name": "screensave.project.capabilities",
      "command": "capabilities",
      "effect": "read-only fixed capability profile",
      "deterministic": true,
      "argv": ["python", "tools/project_adapter/screensave_project.py", "capabilities"],
      "decoder_schema": "tools/project_adapter/receipt_schemas.json#/commands/capabilities",
      "output_policy": "stdout JSON only",
      "input_policy": "none",
      "timeout_seconds": 10,
      "state_probe": "capability_bindings.json digest"
    },
    {
      "name": "screensave.catalog.read",
      "command": "catalog",
      "effect": "read committed generated product inventory",
      "deterministic": true,
      "argv": ["python", "tools/project_adapter/screensave_project.py", "catalog"],
      "decoder_schema": "tools/project_adapter/receipt_schemas.json#/commands/catalog",
      "output_policy": "stdout JSON only",
      "input_policy": "committed catalog/generated/products_inventory.json",
      "timeout_seconds": 10,
      "state_probe": "catalog generated inventory digest"
    },
    {
      "name": "screensave.validation.core",
      "command": "validate",
      "effect": "run bounded ScreenSave-owned validators",
      "deterministic": true,
      "argv": ["python", "tools/project_adapter/screensave_project.py", "validate"],
      "decoder_schema": "tools/project_adapter/receipt_schemas.json#/commands/validate",
      "output_policy": "stdout JSON only",
      "input_policy": "repository validators only",
      "timeout_seconds": 180,
      "state_probe": "validator command receipts"
    },
    {
      "name": "screensave.proof.nocturne.render",
      "command": "render",
      "effect": "write deterministic Nocturne capture artifacts",
      "deterministic": true,
      "argv": ["python", "tools/project_adapter/screensave_project.py", "render", "--invocation-id", "<safe-id>"],
      "decoder_schema": "tools/project_adapter/receipt_schemas.json#/commands/render",
      "output_policy": "contained invocation output root only",
      "input_policy": "bounded Nocturne canary arguments",
      "timeout_seconds": 30,
      "quotas": {
        "max_width": 512,
        "max_height": 512,
        "max_frames": 300,
        "max_delta_ms": 1000
      },
      "state_probe": "sslab render receipt and artifact manifest"
    },
    {
      "name": "screensave.proof.capture.compare",
      "command": "compare",
      "effect": "write capture comparison JSON",
      "deterministic": true,
      "argv": ["python", "tools/project_adapter/screensave_project.py", "compare", "--invocation-id", "<safe-id>"],
      "decoder_schema": "tools/project_adapter/receipt_schemas.json#/commands/compare",
      "output_policy": "contained invocation output root only",
      "input_policy": "captures under validation/captures or out/aide/screensave-project-adapter only",
      "timeout_seconds": 30,
      "quotas": {
        "max_capture_bytes": 52428800
      },
      "state_probe": "sslab comparison receipt and artifact manifest"
    },
    {
      "name": "screensave.artifact.pe.audit",
      "command": "audit",
      "effect": "write PE binary-fact audit report",
      "deterministic": true,
      "argv": ["python", "tools/project_adapter/screensave_project.py", "audit", "--invocation-id", "<safe-id>"],
      "decoder_schema": "tools/project_adapter/receipt_schemas.json#/commands/audit",
      "output_policy": "contained invocation output root only",
      "input_policy": "artifact-profile audit roots from tools/project_adapter/artifact_profile_audit_roots.json",
      "timeout_seconds": 60,
      "quotas": {
        "max_artifact_profiles": 8
      },
      "state_probe": "PE audit report and artifact manifest"
    },
    {
      "name": "screensave.proof.nocturne.exact",
      "command": "proof",
      "effect": "write Nocturne render, exact comparison, and adapter receipt",
      "deterministic": true,
      "argv": ["python", "tools/project_adapter/screensave_project.py", "proof", "--invocation-id", "<safe-id>"],
      "decoder_schema": "tools/project_adapter/receipt_schemas.json#/commands/proof",
      "output_policy": "contained invocation output root only",
      "input_policy": "fixed Nocturne canary and committed validation capture",
      "timeout_seconds": 60,
      "state_probe": "adapter-proof.json and artifact manifest"
    }
  ],
  "refusal_codes": [
    "invalid_invocation_id",
    "output_root_escape",
    "input_not_found",
    "input_not_file",
    "input_root_denied",
    "quota_exceeded",
    "unknown_artifact_profile",
    "command_timeout",
    "command_failed"
  ]
}
