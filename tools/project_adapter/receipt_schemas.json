{
  "schema_version": 1,
  "schema_id": "screensave-project-adapter-receipts-v0",
  "adapter_schema": "screensave-project-adapter-v0",
  "status_values": ["pass", "fail", "informational", "blocked"],
  "common_required": [
    "adapter_schema",
    "project",
    "command",
    "status",
    "source",
    "payload",
    "limits"
  ],
  "commands": {
    "status": {
      "payload_required": ["state_id", "public_release", "development_head", "active_program"]
    },
    "capabilities": {
      "payload_required": ["binding_ref", "binding_sha256", "output_root", "capabilities", "refusals"]
    },
    "catalog": {
      "payload_required": ["inventory_ref", "schema_version", "product_count", "saver_count"]
    },
    "validate": {
      "payload_required": ["validation_class", "command_binding", "runs"]
    },
    "render": {
      "payload_required": [
        "capability",
        "invocation_id",
        "output_dir",
        "artifact_manifest_ref",
        "before_source",
        "after_source",
        "command_binding",
        "run",
        "proof_ref",
        "capture_ref",
        "capture_sha256"
      ]
    },
    "compare": {
      "payload_required": [
        "capability",
        "invocation_id",
        "output_dir",
        "comparison_ref",
        "artifact_manifest_ref",
        "before_source",
        "after_source",
        "command_binding",
        "inputs",
        "run",
        "comparison_status",
        "comparison_class",
        "comparison_metrics"
      ]
    },
    "audit": {
      "payload_required": [
        "capability",
        "invocation_id",
        "output_dir",
        "audit_ref",
        "audit_json_ref",
        "artifact_manifest_ref",
        "before_source",
        "after_source",
        "command_binding",
        "artifact_profiles",
        "artifact_profile_audit_roots_ref",
        "input_paths",
        "run",
        "audit_status",
        "artifact_count",
        "missing_inputs",
        "parse_error_count",
        "violation_count",
        "fail_on_violation",
        "claim_boundary"
      ]
    },
    "proof": {
      "payload_required": [
        "capability",
        "proof_kind",
        "invocation_id",
        "output_dir",
        "artifact_manifest_ref",
        "before_source",
        "after_source",
        "command_binding",
        "render",
        "compare",
        "pe_audit",
        "pe_audit_ref",
        "pe_audit_json_ref",
        "pe_audit_status",
        "pe_audit_artifact_count",
        "pe_audit_missing_inputs",
        "pe_audit_parse_error_count",
        "pe_audit_violation_count",
        "pe_audit_artifact_profiles",
        "pe_audit_claim_boundary",
        "artifact_profile_audit_roots_ref",
        "proof_ref",
        "comparison_ref",
        "capture_ref",
        "capture_sha256",
        "comparison_status",
        "comparison_metrics"
      ]
    },
    "blocked": {
      "payload_required": ["refusal"],
      "refusal_required": ["code", "detail"]
    }
  }
}
