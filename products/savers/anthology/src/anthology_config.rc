#include <windows.h>

#include "anthology_resource.h"

IDD_ANTHOLOGY_CONFIG DIALOG 0, 0, 330, 210
STYLE DS_MODALFRAME | WS_CAPTION | WS_POPUP | WS_SYSMENU
CAPTION "Anthology Settings"
FONT 8, "MS Sans Serif"
BEGIN
    LTEXT "", IDC_ANTHOLOGY_INFO, 8, 8, 314, 22
    LTEXT "Preset", -1, 8, 36, 34, 8
    COMBOBOX IDC_ANTHOLOGY_PRESET, 58, 34, 96, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "Mode", -1, 8, 52, 34, 8
    COMBOBOX IDC_ANTHOLOGY_SELECTION_MODE, 58, 50, 96, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "Interval", -1, 8, 68, 34, 8
    EDITTEXT IDC_ANTHOLOGY_INTERVAL, 58, 66, 34, 12, ES_AUTOHSCROLL | ES_NUMBER | WS_TABSTOP
    LTEXT "sec", -1, 96, 68, 16, 8
    LTEXT "Renderer", -1, 8, 84, 34, 8
    COMBOBOX IDC_ANTHOLOGY_RENDERER_POLICY, 58, 82, 96, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    GROUPBOX "Families", -1, 8, 100, 150, 62
    CONTROL "Quiet", IDC_ANTHOLOGY_FAMILY_QUIET, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 16, 112, 58, 10
    CONTROL "Motion", IDC_ANTHOLOGY_FAMILY_MOTION, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 82, 112, 58, 10
    CONTROL "Vector", IDC_ANTHOLOGY_FAMILY_VECTOR, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 16, 124, 58, 10
    CONTROL "Grid", IDC_ANTHOLOGY_FAMILY_GRID, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 82, 124, 58, 10
    CONTROL "Ambient", IDC_ANTHOLOGY_FAMILY_AMBIENT, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 16, 136, 58, 10
    CONTROL "Places", IDC_ANTHOLOGY_FAMILY_PLACES, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 82, 136, 58, 10
    CONTROL "Worlds", IDC_ANTHOLOGY_FAMILY_WORLDS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 16, 148, 58, 10
    CONTROL "Showcase", IDC_ANTHOLOGY_FAMILY_SHOWCASE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 82, 148, 58, 10

    LTEXT "Savers", -1, 164, 36, 36, 8
    LISTBOX IDC_ANTHOLOGY_SAVER_LIST, 164, 46, 78, 116, LBS_NOTIFY | LBS_NOINTEGRALHEIGHT | WS_BORDER | WS_TABSTOP | WS_VSCROLL
    CONTROL "Enabled", IDC_ANTHOLOGY_SAVER_ENABLED, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 248, 48, 66, 10
    CONTROL "Favorite", IDC_ANTHOLOGY_SAVER_FAVORITE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 248, 60, 66, 10
    LTEXT "Weight", -1, 248, 74, 28, 8
    EDITTEXT IDC_ANTHOLOGY_WEIGHT, 280, 72, 34, 12, ES_AUTOHSCROLL | ES_NUMBER | WS_TABSTOP
    CONTROL "Randomize inner presets", IDC_ANTHOLOGY_RANDOMIZE_PRESETS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 248, 92, 74, 10
    CONTROL "Randomize inner themes", IDC_ANTHOLOGY_RANDOMIZE_THEMES, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 248, 104, 74, 10
    CONTROL "Respect saver-local randomization", IDC_ANTHOLOGY_RESPECT_LOCAL_RANDOMIZATION, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 248, 116, 74, 18
    CONTROL "Use deterministic seed", IDC_ANTHOLOGY_DETERMINISTIC, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 248, 138, 74, 10
    CONTROL "Show diagnostics overlay", IDC_ANTHOLOGY_DIAGNOSTICS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 248, 150, 74, 10

    PUSHBUTTON "Defaults", IDC_ANTHOLOGY_DEFAULTS, 8, 184, 52, 14
    DEFPUSHBUTTON "OK", IDOK, 224, 184, 46, 14
    PUSHBUTTON "Cancel", IDCANCEL, 276, 184, 46, 14
END
