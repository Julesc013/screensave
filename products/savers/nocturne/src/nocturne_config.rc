#include <windows.h>

#include "nocturne_resource.h"

IDD_NOCTURNE_CONFIG DIALOG 0, 0, 236, 152
STYLE DS_MODALFRAME | WS_CAPTION | WS_POPUP | WS_SYSMENU
CAPTION "Nocturne Settings"
FONT 8, "MS Sans Serif"
BEGIN
    LTEXT "", IDC_NOCTURNE_INFO, 8, 8, 220, 24
    LTEXT "Preset", -1, 8, 40, 40, 8
    COMBOBOX IDC_NOCTURNE_PRESET, 72, 38, 120, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "Theme", -1, 8, 56, 40, 8
    COMBOBOX IDC_NOCTURNE_THEME, 72, 54, 120, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "Motion", -1, 8, 72, 40, 8
    COMBOBOX IDC_NOCTURNE_MOTION, 72, 70, 120, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "Fade", -1, 8, 88, 40, 8
    COMBOBOX IDC_NOCTURNE_FADE, 72, 86, 120, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "Strength", -1, 8, 104, 40, 8
    COMBOBOX IDC_NOCTURNE_STRENGTH, 72, 102, 120, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    CONTROL "Use deterministic seed", IDC_NOCTURNE_DETERMINISTIC, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 8, 120, 108, 10
    CONTROL "Show diagnostics overlay", IDC_NOCTURNE_DIAGNOSTICS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 120, 120, 108, 10
    PUSHBUTTON "Defaults", IDC_NOCTURNE_DEFAULTS, 8, 134, 50, 14
    DEFPUSHBUTTON "OK", IDOK, 124, 134, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 178, 134, 50, 14
END
