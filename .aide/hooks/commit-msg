#!/bin/sh
# AIDE local commit-message gate. Install explicitly with:
#   py -3 .aide/scripts/aide_lite.py commit install-hook
#
# The hook is repo-local, standard-library only, and performs no provider,
# model, network, branch, or remote operations.

if command -v py >/dev/null 2>&1; then
  py -3 .aide/scripts/aide_lite.py commit check --message-file "$1"
elif command -v python3 >/dev/null 2>&1; then
  python3 .aide/scripts/aide_lite.py commit check --message-file "$1"
elif command -v python >/dev/null 2>&1; then
  python .aide/scripts/aide_lite.py commit check --message-file "$1"
else
  echo "AIDE commit hook: Python not found; cannot validate commit message." >&2
  echo "Install Python or commit without the AIDE hook only if policy permits." >&2
  exit 1
fi
