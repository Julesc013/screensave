{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIDE Managed Section Operation",
  "type": "object",
  "required": [
    "schema_version",
    "operation_id",
    "path",
    "section_name",
    "marker_family",
    "start_marker",
    "end_marker",
    "start_line",
    "end_line",
    "existing_section_hash",
    "new_section_hash",
    "manual_prefix_hash",
    "manual_suffix_hash",
    "manual_content_preserved",
    "marker_status",
    "conflict_status",
    "allowed",
    "blocked_reason",
    "preimage_ref",
    "postimage_ref",
    "rollback_ref",
    "evidence_refs",
    "no_real_apply_boundary"
  ],
  "properties": {
    "schema_version": {"const": "aide.managed-section-operation.v0"},
    "operation_id": {"type": "string"},
    "path": {"type": "string"},
    "section_name": {"type": "string"},
    "section_id": {"type": "string"},
    "marker_family": {"type": "string"},
    "start_marker": {"type": "string"},
    "end_marker": {"type": "string"},
    "marker_begin": {"type": "string"},
    "marker_end": {"type": "string"},
    "start_line": {"type": "integer", "minimum": 1},
    "end_line": {"type": "integer", "minimum": 1},
    "existing_section_hash": {"type": "string"},
    "new_section_hash": {"type": "string"},
    "manual_prefix_hash": {"type": "string"},
    "manual_suffix_hash": {"type": "string"},
    "manual_content_preserved": {"type": "boolean"},
    "marker_status": {"type": "string"},
    "conflict_status": {"type": "string"},
    "allowed": {"type": "boolean"},
    "blocked_reason": {"type": "string"},
    "preimage_ref": {"type": "string"},
    "postimage_ref": {"type": "string"},
    "rollback_ref": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "no_real_apply_boundary": {"type": "boolean"},
    "replacement": {"type": "string"},
    "preimage_hash": {"type": "string"},
    "postimage_hash": {"type": "string"},
    "real_repo_apply_allowed": {"const": false}
  },
  "additionalProperties": true
}
