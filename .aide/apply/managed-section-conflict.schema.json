{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIDE Managed Section Conflict",
  "type": "object",
  "required": [
    "schema_version",
    "conflict_id",
    "path",
    "section_name",
    "conflict_class",
    "message",
    "severity",
    "apply_blocked",
    "no_real_apply_boundary"
  ],
  "properties": {
    "schema_version": {"const": "aide.managed-section-conflict.v0"},
    "conflict_id": {"type": "string"},
    "path": {"type": "string"},
    "section_name": {"type": "string"},
    "conflict_class": {
      "enum": [
        "missing_start_marker",
        "missing_end_marker",
        "duplicate_start_marker",
        "duplicate_end_marker",
        "nested_marker",
        "malformed_marker",
        "marker_order_invalid",
        "existing_hash_mismatch",
        "manual_content_changed",
        "binary_file",
        "unsupported_encoding",
        "destructive_patch",
        "unknown"
      ]
    },
    "message": {"type": "string"},
    "severity": {"type": "string"},
    "apply_blocked": {"type": "boolean"},
    "no_real_apply_boundary": {"type": "boolean"}
  },
  "additionalProperties": true
}
