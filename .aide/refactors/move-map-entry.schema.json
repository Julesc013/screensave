{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "aide.move-map-entry.schema.v0",
  "type": "object",
  "required": [
    "entry_id",
    "source_path",
    "target_path",
    "status",
    "reason",
    "owner",
    "source_kind",
    "target_owner_hint",
    "identity_sensitive",
    "build_sensitive",
    "authority_sensitive",
    "generated_sensitive",
    "reference_rewrite_required",
    "alias_required",
    "validators_required",
    "rollback_hint",
    "review_required",
    "apply_allowed"
  ],
  "properties": {
    "entry_id": {"type": "string"},
    "source_path": {"type": "string"},
    "target_path": {"type": "string"},
    "status": {"type": "string"},
    "reason": {"type": "string"},
    "owner": {"type": "string"},
    "source_kind": {"type": "string"},
    "target_owner_hint": {"type": "string"},
    "identity_sensitive": {"type": "boolean"},
    "build_sensitive": {"type": "boolean"},
    "authority_sensitive": {"type": "boolean"},
    "generated_sensitive": {"type": "boolean"},
    "reference_rewrite_required": {"type": "boolean"},
    "alias_required": {"type": "boolean"},
    "validators_required": {"type": "array"},
    "rollback_hint": {"type": "string"},
    "review_required": {"type": "boolean"},
    "apply_allowed": {"const": false}
  }
}
