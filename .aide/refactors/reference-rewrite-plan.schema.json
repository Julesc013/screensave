  "properties": {
    "schema_version": {"type": "string"},
    "plan_id": {"type": "string"},
    "generated_by": {"type": "string"},
    "source_commit": {"type": "string"},
    "status": {"type": "string"},
    "source_inputs": {"type": "array"},
    "entries": {"type": "array"},
    "warnings": {"type": "array"},
    "validation": {"type": "array"},
    "no_apply": {"const": true}
  }
}
