  "schema_version": "aide.salvage-map.schema.v0",
  "type": "object",
  "required": [
    "map_id",
    "schema_version",
    "generated_by",
    "source_commit",
    "status",
    "source_path",
    "source_inputs",
    "entries",
    "extracted_items",
    "fates",
    "target_paths",
    "reasons",
    "preservation_notes",
    "warnings",
    "no_apply"
