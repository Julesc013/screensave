    "schema_version": {"type": "string"},
    "generated_by": {"type": "string"},
    "source_commit": {"type": "string"},
    "status": {"type": "string"},
    "source_path": {"type": "string"},
    "source_inputs": {"type": "array"},
    "entries": {"type": "array"},
    "extracted_items": {"type": "array"},
    "fates": {"type": "array"},
    "target_paths": {"type": "array"},
    "reasons": {"type": "array"},
    "preservation_notes": {"type": "array"},
    "warnings": {"type": "array"},
    "no_apply": {"const": true}
