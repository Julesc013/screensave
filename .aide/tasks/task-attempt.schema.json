{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aide.tasks.task-attempt.v0",
  "title": "AIDE TaskAttempt",
  "type": "object",
  "required": [
    "schema_version",
    "attempt_id",
    "workunit_id",
    "actor_type",
    "actor_id",
    "machine_id",
    "branch",
    "base_commit",
    "head_commit",
    "prompt_hash",
    "command_refs",
    "changed_files",
    "validation_run_refs",
    "evidence_refs",
    "result_status",
    "blockers_emitted",
    "warnings",
    "started_at",
    "ended_at",
    "duration_seconds",
    "no_apply_boundary"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "aide.task-attempt.v0" },
    "attempt_id": { "type": "string", "minLength": 1 },
    "workunit_id": { "type": "string", "minLength": 1 },
    "actor_type": { "type": "string", "enum": ["human", "codex", "script", "test_runner", "mixed", "unknown"] },
    "actor_id": { "type": "string" },
    "machine_id": { "type": "string" },
    "branch": { "type": "string" },
    "base_commit": { "type": "string" },
    "head_commit": { "type": "string" },
    "prompt_hash": { "type": "string" },
    "command_refs": { "type": "array", "items": { "type": "string" } },
    "changed_files": { "type": "array", "items": { "type": "string" } },
    "validation_run_refs": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "result_status": { "type": "string" },
    "blockers_emitted": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "started_at": { "type": "string" },
    "ended_at": { "type": "string" },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "no_apply_boundary": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
