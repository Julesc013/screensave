{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aide.tasks.workunit.v0",
  "title": "AIDE WorkUnit",
  "type": "object",
  "required": [
    "schema_version",
    "workunit_id",
    "title",
    "summary",
    "task_class",
    "risk_class",
    "source_prompt_ref",
    "originating_request",
    "status",
    "lifecycle_state",
    "repo_scope",
    "allowed_paths",
    "forbidden_paths",
    "dependencies",
    "blockers",
    "repair_refs",
    "attempt_refs",
    "evidence_refs",
    "validation_refs",
    "capability_refs",
    "branch_refs",
    "created_at",
    "updated_at",
    "review_status",
    "no_apply_boundary"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "aide.workunit.v0" },
    "workunit_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "task_class": { "type": "string" },
    "risk_class": { "type": "string" },
    "source_prompt_ref": { "type": "string" },
    "originating_request": { "type": "string" },
    "status": { "type": "string" },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "proposed",
        "ready",
        "running",
        "done_local",
        "partial",
        "blocked_repairable",
        "blocked_missing_prereq",
        "blocked_needs_decision",
        "blocked_unsafe",
        "repair_queued",
        "resume_ready",
        "merge_candidate",
        "merged_to_dev",
        "checkpoint_candidate",
        "promoted_to_main",
        "quarantined",
        "superseded"
      ]
    },
    "repo_scope": { "type": "string" },
    "allowed_paths": { "type": "array", "items": { "type": "string" } },
    "forbidden_paths": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "repair_refs": { "type": "array", "items": { "type": "string" } },
    "attempt_refs": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "validation_refs": { "type": "array", "items": { "type": "string" } },
    "capability_refs": { "type": "array", "items": { "type": "string" } },
    "branch_refs": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "review_status": { "type": "string", "enum": ["not_required", "pending", "needs_review", "approved", "rejected"] },
    "no_apply_boundary": { "type": "boolean", "const": true }
  },
  "additionalProperties": false
}
