{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aide.capabilities.capability-overclaim.v0",
  "title": "AIDE Capability Overclaim Report",
  "type": "object",
  "required": ["schema_version", "generated_at", "mode", "result", "records", "no_apply_boundary"],
  "properties": {
    "schema_version": { "type": "string", "const": "aide.capability-overclaims.v0" },
    "generated_at": { "type": "string" },
    "mode": { "type": "string", "const": "report_only" },
    "result": { "type": "string" },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["overclaim_id", "capability_id", "overclaim_class", "severity", "blocking", "evidence_refs", "notes"],
        "properties": {
          "overclaim_id": { "type": "string" },
          "capability_id": { "type": "string" },
          "overclaim_class": { "type": "string" },
          "severity": { "type": "string" },
          "blocking": { "type": "boolean" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "no_apply_boundary": { "type": "object" }
  },
  "additionalProperties": false
}
