#include <windows.h>

#include "resource.h"

IDD_SCR_CONFIG DIALOG 0, 0, 220, 116
STYLE DS_MODALFRAME | WS_CAPTION | WS_POPUP | WS_SYSMENU
CAPTION "ScreenSave Settings"
FONT 8, "MS Sans Serif"
BEGIN
    LTEXT "", IDC_SCR_INFO, 8, 8, 204, 28
    CONTROL "Use deterministic seed", IDC_SCR_DETERMINISTIC_SEED, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 8, 46, 110, 10
    CONTROL "Show diagnostics overlay", IDC_SCR_DIAGNOSTICS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 8, 60, 110, 10
    CONTROL "Randomize each session", IDC_SCR_RANDOMIZE_SESSION, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 8, 74, 110, 10
    PUSHBUTTON "Defaults", IDC_SCR_RESET_DEFAULTS, 8, 96, 50, 14
    DEFPUSHBUTTON "OK", IDOK, 108, 96, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 162, 96, 50, 14
END

IDD_SCR_PRODUCT_SELECT DIALOG 0, 0, 236, 124
STYLE DS_MODALFRAME | WS_CAPTION | WS_POPUP | WS_SYSMENU
CAPTION "ScreenSave Product"
FONT 8, "MS Sans Serif"
BEGIN
    LTEXT "Current saver", -1, 8, 10, 60, 8
    COMBOBOX IDC_SCR_PRODUCT, 72, 8, 124, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT "Renderer", -1, 8, 30, 60, 8
    COMBOBOX IDC_SCR_RENDERER, 72, 28, 124, 64, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON "Settings...", IDC_SCR_PRODUCT_SETTINGS, 156, 46, 40, 14
    LTEXT "", IDC_SCR_PRODUCT_INFO, 8, 50, 220, 54
    DEFPUSHBUTTON "OK", IDOK, 124, 104, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 178, 104, 50, 14
END

IDD_SCR_SAVER_SHELL DIALOG 0, 0, 228, 136
STYLE DS_MODALFRAME | WS_CAPTION | WS_POPUP | WS_SYSMENU
CAPTION "ScreenSave Settings"
FONT 8, "MS Sans Serif"
BEGIN
    LTEXT "", IDC_SCR_INFO, 8, 8, 212, 38
    LTEXT "Renderer", -1, 8, 52, 44, 8
    COMBOBOX IDC_SCR_RENDERER, 60, 50, 110, 64, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON "Settings...", IDC_SCR_PRODUCT_SETTINGS, 176, 50, 44, 14
    CONTROL "Use deterministic seed", IDC_SCR_DETERMINISTIC_SEED, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 8, 72, 110, 10
    CONTROL "Show diagnostics overlay", IDC_SCR_DIAGNOSTICS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 8, 86, 110, 10
    CONTROL "Randomize each session", IDC_SCR_RANDOMIZE_SESSION, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 8, 100, 110, 10
    PUSHBUTTON "Defaults", IDC_SCR_RESET_DEFAULTS, 8, 116, 50, 14
    DEFPUSHBUTTON "OK", IDOK, 116, 116, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 170, 116, 50, 14
END
