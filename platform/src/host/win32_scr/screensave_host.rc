#include <windows.h>

#include "resource.h"

IDD_SCR_CONFIG DIALOG 0, 0, 220, 92
STYLE DS_MODALFRAME | WS_CAPTION | WS_POPUP | WS_SYSMENU
CAPTION "ScreenSave Settings"
FONT 8, "MS Sans Serif"
BEGIN
    LTEXT "", IDC_SCR_INFO, 8, 8, 204, 24
    CONTROL "Enable placeholder visual", IDC_SCR_PLACEHOLDER_VISUAL, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 8, 38, 110, 10
    CONTROL "Show diagnostics overlay", IDC_SCR_DIAGNOSTICS, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 8, 52, 110, 10
    PUSHBUTTON "Defaults", IDC_SCR_RESET_DEFAULTS, 8, 72, 50, 14
    DEFPUSHBUTTON "OK", IDOK, 108, 72, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 162, 72, 50, 14
END
